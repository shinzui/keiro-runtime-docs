# oxfmt reads this file by default (alongside .gitignore) to decide what NOT to format.
# Scope the format gate to the docs SITE (src/, content/docs/, root config); exclude:

# Generated / build output (also gitignored, listed for clarity)
.source/
.output/
.nitro/
.tanstack/
result/
node_modules/

# Generated, committed route tree — regenerated unformatted by `vite build`/`vite dev`,
# so formatting it would make the gate flap after every build.
src/routeTree.gen.ts

# Generated lockfile — owned by pnpm, not a formatting target.
pnpm-lock.yaml

# Vendored skill/tooling definitions — not part of the docs site.
agents/

# Planning documents (ExecPlans / MasterPlans) — prose with embedded code/mermaid fences
# that oxfmt cannot format stably; they are not site content. Anchored to the repo root with
# a leading slash so it does NOT also match `content/docs/` (which IS site content and is
# format-checked).
/docs/
