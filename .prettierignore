# oxfmt reads this file by default (alongside .gitignore) to decide what NOT to format.
# Scope the format gate to the application CODE (src/, scripts/, root config). The
# hand-authored docs content is excluded — see the "Docs content" section below.

# Generated / build output (also gitignored, listed for clarity)
.source/
.output/
.nitro/
.tanstack/
result/
node_modules/

# Generated, committed route tree — regenerated unformatted by `vite build`/`vite dev`,
# so formatting it would make the gate flap after every build.
src/routeTree.gen.ts

# Generated lockfile — owned by pnpm, not a formatting target.
pnpm-lock.yaml

# Vendored skill/tooling definitions — not part of the docs site.
agents/

# Planning documents (ExecPlans / MasterPlans) — prose with embedded code/mermaid fences.
/docs/

# Docs content — hand-authored MDX (and the per-folder meta.json sidebar files) is NOT
# oxfmt territory. oxfmt 0.45.0 cannot format this MDX safely: it is non-idempotent on
# nested `<Steps>`/`<Step>` JSX (it flip-flops the indentation every run, so `--check` can
# never settle) and it MIS-NESTS closing JSX tags inside list items — e.g. it moved a
# `</Callout>` out of its `listItem` in keiki/explanation/the-regfile-codec-and-snapshots.mdx,
# producing MDX that no longer parses and breaks `pnpm build`. The docs have their own
# authoring/style guide (content/docs/getting-started/contributing.mdx); they are reviewed by
# hand, not by oxfmt. Re-evaluate if a future oxfmt fixes its MDX formatter.
content/
