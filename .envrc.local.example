# Optional licensed PragmataPro setup.
#
# Copy this to .envrc.local only if you own the font package. The file is ignored
# by git so personal paths never enter the public repository.
#
# Option A: point to a Nix flake that exposes packages.<system>.pragmataPro.
# export PRAGMATAPRO_FLAKE="path:/absolute/path/to/fonts"
#
# Option B: point directly at a directory containing the OTF files, or at a
# package output that contains share/fonts/opentype.
# export PRAGMATAPRO_FONT_DIR="/absolute/path/to/share/fonts/opentype"
#
# Option C: leave this file unset and add a local Nix registry alias instead:
# nix registry add pragmatapro path:/absolute/path/to/fonts
